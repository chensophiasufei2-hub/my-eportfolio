    "#| echo: true\n",
    "#| code-fold: true\n",
    "#| fig-cap: \"Example Python visualisation of category-level business performance\"\n",
    "\n",
    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "data = pd.DataFrame({\n",
    "    \"Category\": [\"Travel\", \"Construction\", \"Electronics\", \"Finance\", \"Retail\"],\n",
    "    \"Net_Profit\": [82, 76, -14, 58, 41]\n",
    "})\n",
    "\n",
    "plt.figure(figsize=(8, 5))\n",
    "plt.bar(data[\"Category\"], data[\"Net_Profit\"])\n",
    "plt.title(\"Net Profit by Category\")\n",
    "plt.xlabel(\"Category\")\n",
    "plt.ylabel(\"Net Profit\")\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
